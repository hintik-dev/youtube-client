{
    "name": "hintik/youtube-client",
    "description": "YouTube Data API v3 PHP client",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jan Hinterholzinger",
            "email": "hintik@icloud.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "php-http/cache-plugin": "^1.8",
        "php-http/client-common": "^2.7",
        "php-http/discovery": "^1.20",
        "php-http/multipart-stream-builder": "^1.4",
        "psr/cache": "^1.0 || ^2.0 || ^3.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "symfony/options-resolver": "^6.0 || ^7.0 || ^8.0"
    },
    "suggest": {
        "symfony/http-client": "PSR-18 HTTP client implementation",
        "nyholm/psr7": "PSR-7 and PSR-17 factory implementation"
    },
    "autoload": {
        "psr-4": {
            "Hintik\\YouTube\\": "src/"
        }
    },
    "minimum-stability": "stable"
}